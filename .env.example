# random hex, e.g. `openssl rand -hex 32`; rotating it logs out all devices
SESSION_SECRET=
# Turso: `turso db show tracker --url` / `turso db tokens create tracker`
# locally you can use TURSO_DATABASE_URL=file:data/tracker.db and omit the token
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# accounts are created with: pnpm add-user <username> <password>
